  statText: {
    color: colors.text,
    fontSize: fontSize.bodyLarge,
    fontWeight: "600",
  },
  actionText: {
    color: colors.primary,
    fontSize: fontSize.caption,
    fontWeight: "800",
  },
  indicatorRow: { flexDirection: "row", justifyContent: "center", gap: 6 },
  indicator: {
    width: 6,
    height: 6,
    borderRadius: 3,
    backgroundColor: colors.border,
  },
  indicatorActive: { width: 18, backgroundColor: colors.primary },
  feedCard: {
    borderRadius: radius.lg,
    backgroundColor: colors.surface,
    borderWidth: 1,
    borderColor: colors.border,
    padding: spacing.lg,
    gap: spacing.xs,
  },
  feedTitle: {
    color: colors.text,
    fontSize: fontSize.cardTitle,
    fontWeight: "700",
  },
  feedBody: { color: colors.muted, fontSize: fontSize.body, lineHeight: 20 },
  feedAction: {
    color: colors.primary,
