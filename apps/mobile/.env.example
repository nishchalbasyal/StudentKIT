#
# Mobile API configuration
#
# Local Android emulator:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:4000/api
#
# Local physical device on same Wi-Fi:
# EXPO_PUBLIC_API_URL=http://YOUR_PC_LAN_IP:4000/api
#
# Production:
# EXPO_PUBLIC_API_URL=https://api.your-domain.com/api
#
EXPO_PUBLIC_API_URL=http://localhost:4000/api
EXPO_PUBLIC_API_PORT=4000

#
# Google Sign-In Configuration
# Get this from Google Cloud Console -> Credentials -> OAuth 2.0 Client ID (Web)
#
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=230557035905-ckgt65316n8nlmgf63r2cg8niqlkg6dv.apps.googleusercontent.com
